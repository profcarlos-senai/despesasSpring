meta {
  name: cria novo
  type: http
  seq: 2
}

post {
  url: {{baseurl}}/{{path}}
  body: json
  auth: inherit
}

body:json {
  {
    "nome": "Junk food"
  }
}

assert {
  res.status: eq 200
  res.body.nome: eq {{nomeNovo}}
}

script:post-response {
  if (res.status>=200 && res.status<300){
    bru.setVar("idNovo",res.body.id);
    bru.setVar("nomeNovo", res.body.nome)
  }
  console.log('idnovo={{idNovo}}, idnome={{nomeNovo}}');
}
