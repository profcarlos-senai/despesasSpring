meta {
  name: muda nome
  type: http
  seq: 6
}

put {
  url: {{baseurl}}/{{caminho}}/{{idNovo}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": {{idNovo}},
    "nome": "Espetinho de gato"
  }
}

assert {
  res.status: eq 200
  res.body.id: eq {{idNovo}}
  res.body.nome: eq "Espetinho de gato"
}
